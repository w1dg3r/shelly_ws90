  "1.4.1": {
    "en": "Fixed 'N/A' issue for wind direction in Analytics device. Switched to standard system icons for better UI consistency. Removed temporary SVG assets."
  },
  "1.4.0": {
    "en": "Added WS90 Analytics Insights device with Beaufort wind scale, wind direction as text, rain rate, pressure trend, solar drying index, frost warning and rain prediction. Fixed rain alarm label to 'Wet'. Enabled Insights graphs for all custom rain capabilities. Code quality improvements."
  },
  "name": {
    "en": "WS90 Weather (MQTT)"
  },
  "description": {
    "en": "Real-time weather monitoring from your WS90 station"
  },
  "brandColor": "#4A90E2",
  "category": [
    "climate"
