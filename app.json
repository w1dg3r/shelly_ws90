    "deleteLogs": {
      "method": "delete",
      "path": "/logs"
    },
    "getStatus": {
      "method": "get",
      "path": "/status"
    }
  },
  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Frost risk cleared"
        },
        "hint": {
          "en": "Triggers when frost risk conditions are no longer present."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=ws90_analytics"
          }
        ],
        "id": "frost_warning_off"
      },
      {
        "title": {
          "en": "Frost risk detected"
        },
        "hint": {
          "en": "Triggers when conditions indicate a risk of frost (temperature ≤ 3°C and high humidity)."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=ws90_analytics"
          }
        ],
        "id": "frost_warning_on"
      },
      {
        "title": {
          "en": "Rain no longer expected"
        },
        "hint": {
          "en": "Triggers when rain prediction conditions are no longer met."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=ws90_analytics"
          }
        ],
        "id": "rain_imminent_off"
      },
      {
        "title": {
          "en": "Rain expected soon"
        },
        "hint": {
          "en": "Triggers when falling pressure, high humidity and increasing wind indicate imminent rain."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=ws90_analytics"
          }
        ],
        "id": "rain_imminent_on"
      }
    ]
  },
